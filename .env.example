# Configure these only in Vercel Project Settings > Environment Variables.
# Never commit real values.
DASHBOARD_PASSWORD=replace-with-a-long-unique-password
SESSION_SECRET=replace-with-at-least-32-random-characters

# Optional: replace the safe private snapshot with reviewed management totals.
# Do not include bank credentials, Social Security numbers, client names,
# account numbers, payment-card data, or raw transaction records.
PRIVATE_DASHBOARD_DATA_JSON=
